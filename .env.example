# ─── Auth ──────────────────────────────────────────────────────
# Login passwords (leads: Zaal + Iman; workers: ThyRev, Samantha, Tyler)
# Phase B (Supabase 001 migration) added DB-backed users, but these env
# vars stay as a fast-path for the 5 hardcoded roster slots.
ZAAL_PASSWORD=changeme-zaal
IMAN_PASSWORD=changeme-iman
THYREV_PASSWORD=changeme-thyrev
SAMANTHA_PASSWORD=changeme-samantha
TYLER_PASSWORD=changeme-tyler

# Cookie signing secret — required 32+ chars (doc 762 NEW-C).
# Generate: openssl rand -hex 32
AUTH_SECRET=replace-with-random-32-byte-hex

# ─── AI chat (Assistant tab) ───────────────────────────────────
# Without MINIMAX_API_KEY the /chat page still loads but a send returns 503.
# Key is used server-side only, never sent to the client.
# Get a key: https://platform.minimax.io/
MINIMAX_API_KEY=
# Optional overrides — defaults shown.
MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=MiniMax-M2.7

# ─── Supabase ──────────────────────────────────────────────────
# Server-side only (used by src/lib/data.ts). The web app reads tasks +
# team_members + brands + audit_logs through the service key.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Public client keys (currently unused by the web app but documented for
# parity with the agent/ subdir which uses these for Telegram bot reads).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── GitHub webhook (doc 763 F3) ───────────────────────────────
# When a PR title matches `cowork#<id>` the webhook moves the linked task
# from TODO -> WIP (on open) and WIP -> DONE (on merge). Generate via
# GitHub repo Settings -> Webhooks -> Add webhook -> set Content type to
# application/json, Secret to whatever you put here, Events to "Pull
# requests" + "Pull request reviews". Point payload URL at /api/github/webhook.
GITHUB_WEBHOOK_SECRET=
# Repo the webhook covers (also used by agent/src/roster.ts for team.json).
GITHUB_REPO=ZAODEVZ/ZAOcowork
GITHUB_BRANCH=main

# ─── Comment notifications (Telegram group ping) ───────────────
# When set, a new comment posts to the ZAO DEVZ Telegram group, tagging the
# people who should see it (@mentions + task owner + prior commenters + leads).
# Unset = feature is a no-op (comments still save normally).
#
# TELEGRAM_BOT_TOKEN: same @ZAOcoworkingBot token (from @BotFather).
# TELEGRAM_GROUP_CHAT_ID: the group/supergroup chat id (negative number). Add the
#   bot to the group, then read the chat id from getUpdates or @userinfobot.
# APP_BASE_URL: origin used to build the /todo/<id> task link in the ping.
#
# NOTE: the 1-hour "no reaction -> DM" escalation is NOT handled here (Vercel is
# serverless). That lives in the ZAO OS repo. This is the group ping only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
APP_BASE_URL=https://www.thezao.xyz

# ─── Meetings → Google Calendar (shared calendar / service account) ───
# Optional. Without these, meetings still work + email invites still send;
# they just won't push to a shared Google calendar.
#   GOOGLE_SERVICE_ACCOUNT_JSON: the full service-account key JSON (as a string).
#     Create a service account in Google Cloud, enable the Calendar API, download
#     the JSON key. Share the target calendar with the service account's
#     client_email and grant "Make changes to events".
#   GOOGLE_CALENDAR_ID: the calendar id to write to (e.g. the shared "ZAO"
#     calendar's id, or "primary" of an account the SA can access).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=
# Email invites reuse RESEND_API_KEY + DIGEST_FROM_ADDRESS (see the digest section).

# ─── Future ────────────────────────────────────────────────────
# Bot API key for the Hermes imanagent integration
HERMES_API_KEY=
