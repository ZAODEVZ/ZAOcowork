# ZAOcoworkingBot v2 environment.
# Copy to .env (chmod 600). Never commit .env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed in DM
# DM @userinfobot to get a user's ID
ALLOWLIST_USER_IDS=

# Comma-separated Telegram chat IDs (negative for groups/supergroups) where the
# bot replies on @mention
ALLOWLIST_CHAT_IDS=

# Map of telegram_user_id -> Owner enum value for action ownership
# Format: ID:Name,ID:Name,...
USER_NAMES=1447437687:Zaal

# Admin Telegram IDs (can run /daily etc)
ADMIN_USER_IDS=1447437687

# Supabase - the unified `tasks` table backend (doc 692).
# Project URL + service role key. Service key is server-side only, never
# exposed to a browser. Get both from Supabase dashboard > Project Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Fine-grained GitHub PAT - roster file (ROSTER.md) read/write only.
# The action tracker no longer uses GitHub; it reads/writes Supabase.
# Create at https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Optional - override defaults
# COWORK_HOME=/root/.zaocoworking
# GITHUB_REPO=ZAODEVZ/ZAOcowork
# GITHUB_BRANCH=main

# /juke command - create ZAO Live audio spaces via the ZAOOS Path B route.
# JUKE_CREATE_PASSWORD must match the value set on ZAOOS (zaoos.com).
# Without it, /juke replies that creation is not set up.
JUKE_CREATE_PASSWORD=
# ZAOOS_API_BASE overrides the ZAOOS origin the /juke command POSTs to.
# Defaults to https://zaoos.com.
# ZAOOS_API_BASE=https://zaoos.com

# v2.5 - default LLM provider + model (when user has no per-user pref).
# Providers: claude-max | claude-api | openai | minimax
# claude-max = local CLI subprocess, uses Max OAuth, $0. Default.
# DEFAULT_LLM_PROVIDER=claude-max
# DEFAULT_LLM_MODEL=haiku

# v2.5 - env-level API keys (fallback when user has no BYOK)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_API_URL=https://api.minimaxi.chat/v1/text/chatcompletion_v2

# doc 669 Phase 1 - ZABAL Bonfire integration.
# Hook is no-op until all 3 are set + BONFIRE_ENABLED=true.
# Get key by signing the reveal message at https://app.bonfires.ai/dashboard.
# Get bonfire id from the same dashboard (the ZABAL bonfire UUID).
# BONFIRE_API_KEY=
# BONFIRE_ID=
# BONFIRE_API_URL=https://tnt-v2.api.bonfires.ai
# BONFIRE_ENABLED=true
# BONFIRE_DEFAULT_BRAND=ZAO
