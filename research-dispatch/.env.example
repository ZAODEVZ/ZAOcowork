# research-dispatch required env (VPS-side)
#
# Copy to ~/.research-dispatch.env on the VPS (the cron script sources this path).
# Lock permissions: chmod 600 ~/.research-dispatch.env

# Bonfire knowledge graph push
BONFIRE_API_KEY=
BONFIRE_ID=69ef871f0d22ed7e6f2b243a
BONFIRE_API_URL=https://tnt-v2.api.bonfires.ai

# Repo paths on the VPS (absolute)
RESEARCH_DISPATCH_DIR=/home/zao/repos/ZAOcowork/research-dispatch
ZABALGAMES_REPO_PATH=/home/zao/repos/zabalgames

# GitHub auth - PAT with `repo` scope so the dispatch can commit + push
# to both ZAODEVZ/ZAOcowork (queue updates) and ZAODEVZ/zabalgames (graph file).
GH_TOKEN=

# Claude Code CLI (Max plan OAuth pre-authed via `claude auth login`)
CLAUDE_CODE_BIN=claude
MAX_TURNS_PER_SUBAGENT=40
SUBAGENT_TIMEOUT_MS=900000

# Telegram notifications (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=
